    <child link="link7"/>
    <axis xyz="0 0 1"/>
    <limit effort="20" lower="-6.28318530718" upper="6.28318530718" velocity="3.14"/>
    <dynamics damping="2" friction="1"/>
  </joint>
  <joint name="joint_eef" type="fixed">
    <origin xyz="0 0 0.008" rpy="0 0 1.57079"/>
    <parent link="link7"/>
    <child link="panda_hand"/>
  </joint>
  <link name="panda_hand">
    <visual>
      <geometry>
        <mesh filename="../panda_gripper/meshes/visual/hand.glb"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.570795 0 0" xyz="0 0 0.02617"/>
      <geometry>
        <box size="0.036 0.08 0.2"/>
      </geometry>
    </collision>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.0003"/>
      <geometry>
