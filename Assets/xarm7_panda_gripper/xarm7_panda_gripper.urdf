      <geometry>
        <mesh filename="../panda_gripper/meshes/visual/finger.glb"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 -18.5e-3 11e-3"/>
      <geometry>
        <box size="22e-3 15e-3 20e-3"/>
