  </joint>
  <link name="link7">
    <inertial>
      <origin rpy="0 0 0" xyz="0 -0.00677 -0.01098"/>
      <mass value="0.17"/>
      <inertia ixx="9.3e-05" ixy="-0.0" ixz="-0.0" iyy="5.87e-05" iyz="-3.6e-06" izz="0.000132"/>
