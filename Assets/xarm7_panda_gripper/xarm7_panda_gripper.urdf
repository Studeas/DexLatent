<?xml version="1.0" encoding="utf-8"?>
<!-- xarm7 + Panda gripper: link7 -> joint_eef -> panda_hand -> fingers -->
<!-- xarm7 meshes: https://github.com/sapien-sim/xarm7 -->
<robot name="xarm7_panda_gripper">
  <link name="link_base">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.021131 -0.0016302 0.056488"/>
      <mass value="0.88556"/>
      <inertia ixx="0.0030595" ixy="0.00012259" ixz="-0.00062705" iyy="0.0037783" iyz="0.00027023" izz="0.0020125"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="../xarm7/meshes/visual/link_base.glb"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../xarm7/meshes/collision/link_base.obj"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
  </link>
  <link name="link1">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0002 0.02905 -0.01233"/>
      <mass value="2.382"/>
      <inertia ixx="0.0056905" ixy="-1.579e-05" ixz="5.125e-06" iyy="0.0049566" iyz="-0.000873378" izz="0.003316654"/>
