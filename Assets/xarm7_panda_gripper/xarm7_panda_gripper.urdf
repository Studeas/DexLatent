  </link>
  <joint name="joint2" type="revolute">
    <origin rpy="-1.5708 0 0" xyz="0 0 0"/>
    <parent link="link1"/>
    <child link="link2"/>
    <axis xyz="0 0 1"/>
    <limit effort="50" lower="-2.059" upper="2.0944" velocity="3.14"/>
    <dynamics damping="10" friction="1"/>
  </joint>
  <link name="link3">
